{
  "manifest_version": 3,
  "name": "Gelişim Raporu Asistanı",
  "version": "2.1.7",
  "description": "Gelişim raporu formlarını not tabanlı veya manuel olarak doldurur ve temizler. Giriş gerektirmez.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://e-okul.meb.gov.tr/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://e-okul.meb.gov.tr/OrtaOgretim/OKL/OOK07015.aspx*",
        "https://e-okul.meb.gov.tr/IlkOgretim/OKL/IOK10016.aspx*"
      ],
      "js": ["content/panel.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://e-okul.meb.gov.tr/OrtaOgretim/OKL/OOK07003.aspx*",
        "https://e-okul.meb.gov.tr/IlkOgretim/OKL/IOK10007.aspx*"
      ],
      "js": ["content/scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Gelişim Raporu Asistanı",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
